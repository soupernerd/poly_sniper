# PolySnipe environment template
# Preferred path (from repo root):
# - Windows: setup-public.bat
# - macOS/Linux: ./setup-public.sh (or python3 scripts/setup_public.py)
# The setup script creates app/.env and auto-generates these values.
# Never commit your real app/.env file.

# Required: Polymarket wallet + API creds
POLYMARKET_PRIVATE_KEY=your_private_key_here
POLYMARKET_WALLET_ADDRESS=0xYourPolygonWalletAddress
POLYMARKET_API_KEY=your_api_key_here
POLYMARKET_API_SECRET=your_api_secret_here
POLYMARKET_API_PASSPHRASE=your_api_passphrase_here

# Optional: improves wallet balance readout in dashboard/snipe-view
# Get a key from https://polygonscan.com/apis
POLYGONSCAN_API_KEY=

# Optional monitor tuning (leave as 1 unless you know why to change)
MONITOR_V2_COMPACT_METADATA_WRITES=1
